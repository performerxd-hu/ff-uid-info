import discord
from discord.ext import commands
from discord import app_commands
import aiohttp
from datetime import datetime
import json
import os
import asyncio

class InfoCommands(commands.Cog):
    def __init__(self, bot):
        self.bot = bot
        self.api_url = "http://raw.thug4ff.xyz/info"
        self.session = None
        self.default_region = "IND"  # ← Default region added

    async def cog_load(self):
        self.session = aiohttp.ClientSession()

    async def cog_unload(self):
        if self.session:
            await self.session.close()

    def convert_unix_timestamp(self, timestamp):
        try:
            if timestamp and timestamp > 0:
                return datetime.utcfromtimestamp(timestamp).strftime('%d-%m-%Y %H:%M:%S')
            return "Not available"
        except:
            return "Not available"

    @commands.hybrid_command(name="info", description="Get FreeFire player information by UID")
    @app_commands.describe(uid="FreeFire player UID (e.g., 2266255397)")
    async def player_info(self, ctx: commands.Context, uid: str):
        # Validate UID
        if not uid.isdigit() or len(uid) < 6:
            embed = discord.Embed(
                title="❌ Invalid UID",
                description="UID must:\n• Contain only numbers\n• Have at least 6 digits",
                color=discord.Color.red()
            )
            await ctx.send(embed=embed)
            return

        await ctx.defer()
        
        try:
            # Using default region IND
            async with self.session.get(f"{self.api_url}?uid={uid}&key=great&region={self.default_region}") as response:
                if response.status == 404:
                    embed = discord.Embed(
                        title="❌ Player Not Found",
                        description=f"Player with UID `{uid}` not found in region `{self.default_region}`.\n\n⚠️ **Note:** Some servers may be temporarily unavailable.",
                        color=discord.Color.red()
                    )
                    await ctx.send(embed=embed)
                    return
                    
                if response.status != 200:
                    embed = discord.Embed(
                        title="⚠️ API Error",
                        description="The API is not responding. Try again later.",
                        color=discord.Color.orange()
                    )
                    await ctx.send(embed=embed)
                    return
                    
                data = await response.json()

            # Extract data
            basic_info = data.get('basicInfo', {})
            captain_info = data.get('captainBasicInfo', {})
            clan_info = data.get('clanBasicInfo', {})
            credit_score_info = data.get('creditScoreInfo', {})
            pet_info = data.get('petInfo', {})
            profile_info = data.get('profileInfo', {})
            social_info = data.get('socialInfo', {})

            region = basic_info.get('region', self.default_region).upper()
            nickname = basic_info.get('nickname', 'Unknown')
            
            # Create embed
            embed = discord.Embed(
                title=f"🎮 {nickname}",
                description=f"**UID:** `{uid}` | **Region:** `{region}`",
                color=discord.Color.green(),
                timestamp=datetime.now()
            )
            
            # Account Basic Info
            embed.add_field(
                name="📊 Account Basic Info",
                value=f"```\n"
                      f"Level: {basic_info.get('level', 'N/A')}\n"
                      f"Exp: {basic_info.get('exp', 'N/A')}\n"
                      f"Region: {region}\n"
                      f"Likes: {basic_info.get('liked', 'N/A')}\n"
                      f"Honor Score: {credit_score_info.get('creditScore', 'N/A')}\n"
                      f"Signature: {social_info.get('signature', 'None')[:50]}\n"
                      f"```",
                inline=False
            )
            
            # Ranks
            embed.add_field(
                name="🏆 Ranks",
                value=f"```\n"
                      f"BR Rank: {basic_info.get('rank', 'N/A')}\n"
                      f"BR Points: {basic_info.get('rankingPoints', 'N/A')}\n"
                      f"CS Rank: {basic_info.get('csRank', 'N/A')}\n"
                      f"CS Points: {basic_info.get('csRankingPoints', 'N/A')}\n"
                      f"```",
                inline=True
            )
            
            # Activity
            embed.add_field(
                name="⏱️ Activity",
                value=f"```\n"
                      f"Created: {self.convert_unix_timestamp(basic_info.get('createAt'))}\n"
                      f"Last Login: {self.convert_unix_timestamp(basic_info.get('lastLoginAt'))}\n"
                      f"Release: {basic_info.get('releaseVersion', 'N/A')}\n"
                      f"Badges: {basic_info.get('badgeCnt', 'N/A')}\n"
                      f"```",
                inline=True
            )
            
            # Clan Info
            if clan_info:
                embed.add_field(
                    name="👥 Clan Info",
                    value=f"```\n"
                          f"Name: {clan_info.get('clanName', 'N/A')}\n"
                          f"Level: {clan_info.get('clanLevel', 'N/A')}\n"
                          f"Members: {clan_info.get('memberNum', '0')}/{clan_info.get('capacity', '0')}\n"
                          f"```",
                    inline=False
                )
            
            # Pet Info
            if pet_info and pet_info.get('isSelected'):
                embed.add_field(
                    name="🐾 Pet Info",
                    value=f"```\n"
                          f"Name: {pet_info.get('name', 'N/A')}\n"
                          f"Level: {pet_info.get('level', 'N/A')}\n"
                          f"Exp: {pet_info.get('exp', 'N/A')}\n"
                          f"```",
                    inline=True
                )
            
            # Profile
            embed.add_field(
                name="🎨 Profile",
                value=f"```\n"
                      f"Avatar ID: {profile_info.get('avatarId', 'N/A')}\n"
                      f"Banner ID: {basic_info.get('bannerId', 'N/A')}\n"
                      f"Equipped Skills: {profile_info.get('equipedSkills', 'N/A')}\n"
                      f"```",
                inline=True
            )
            
            embed.set_footer(text="PHANTOM X BOT | Data from FreeFire API")
            
            await ctx.send(embed=embed)
            
            # Try to send outfit image
            try:
                image_url = f"http://profile.thug4ff.xyz/api/profile?uid={uid}"
                async with self.session.get(image_url) as img_response:
                    if img_response.status == 200:
                        from io import BytesIO
                        import uuid
                        image_data = await img_response.read()
                        file = discord.File(BytesIO(image_data), filename=f"outfit_{uuid.uuid4().hex[:8]}.png")
                        await ctx.send(file=file)
            except Exception as e:
                print(f"Image generation failed: {e}")

        except Exception as e:
            embed = discord.Embed(
                title="❌ Error",
                description=f"```\n{str(e)[:200]}\n```",
                color=discord.Color.red()
            )
            await ctx.send(embed=embed)

async def setup(bot):
    await bot.add_cog(InfoCommands(bot))
